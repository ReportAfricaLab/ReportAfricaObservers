# ============================================
# ReportAfrica — Production Environment Config
# ============================================
# Copy this file and fill in real values:
#   cp .env.production.example .env.production

# === Database (PostgreSQL + PostGIS) ===
DATABASE_HOST=your-rds-endpoint.af-south-1.rds.amazonaws.com
DATABASE_PORT=5432
DATABASE_NAME=reportafrica
DATABASE_USER=reportafrica_admin
DATABASE_PASSWORD=<strong-password>

# === Redis (ElastiCache) ===
REDIS_HOST=your-elasticache-endpoint.af-south-1.cache.amazonaws.com
REDIS_PORT=6379

# === JWT Auth ===
JWT_SECRET=<generate-with: openssl rand -base64 64>
JWT_EXPIRATION=7d

# === AWS Core ===
AWS_REGION=af-south-1
AWS_ACCESS_KEY_ID=<access-key>
AWS_SECRET_ACCESS_KEY=<secret-key>

# === AWS S3 (Media Storage) ===
AWS_S3_BUCKET=reportafrica-media-prod
# CloudFront distribution URL for fast media delivery
CLOUDFRONT_URL=https://d1234567890.cloudfront.net

# === AWS IVS (Livestreaming) ===
AWS_IVS_RECORDING_ARN=arn:aws:ivs:us-east-1:ACCOUNT_ID:recording-configuration/xxx

# === OpenAI (AI Moderation & Verification) ===
OPENAI_API_KEY=sk-xxx

# === Paystack (Donations) ===
PAYSTACK_SECRET_KEY=sk_live_xxx
PAYSTACK_CALLBACK_URL=https://reportafrica.com/donations/verify

# === Kora Pay (Media Licensing) ===
KORAPAY_SECRET_KEY=sk_live_xxx
KORAPAY_PUBLIC_KEY=pk_live_xxx
KORAPAY_WEBHOOK_URL=https://api.reportafrica.com/api/v1/media-licensing/webhook/korapay
KORAPAY_REDIRECT_URL=https://reportafrica.com/media-licensing/payment-complete

# === Firebase Cloud Messaging ===
FCM_SERVER_KEY=<fcm-server-key>

# === Sentry Error Tracking ===
SENTRY_DSN=https://xxx@o123456.ingest.sentry.io/xxx

# === App Config ===
PORT=3001
NODE_ENV=production

# === Web App (Next.js) ===
NEXT_PUBLIC_API_URL=https://api.reportafrica.com/api/v1
NEXT_PUBLIC_WS_URL=https://api.reportafrica.com/realtime
NEXT_PUBLIC_MAPBOX_TOKEN=pk.xxx
NEXT_PUBLIC_GOOGLE_CLIENT_ID=xxx.apps.googleusercontent.com
NEXT_PUBLIC_SENTRY_DSN=https://xxx@o123456.ingest.sentry.io/xxx
